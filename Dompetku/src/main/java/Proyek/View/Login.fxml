<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="Proyek.View.LoginController">
   <children>
      <VBox layoutX="50.0" layoutY="80.0" prefHeight="240.0" prefWidth="400.0" spacing="15.0">
         <children>
            <Label text="LOGIN DOMPETKU" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            
            <VBox spacing="5.0">
               <Label text="Nama Akun" />
               <TextField fx:id="namaAkunInput" promptText="Masukkan nama akun" />
            </VBox>
            
            <VBox spacing="5.0">
               <Label text="Sandi" />
               <PasswordField fx:id="sandiInput" promptText="Masukkan sandi" />
            </VBox>
            
            <HBox spacing="20.0" prefWidth="400.0">
               <Button text="Login" prefWidth="100.0" style="-fx-font-size: 12; -fx-padding: 8;" onAction="#handleLoginAction"/>
               <Button text="Reset" prefWidth="100.0" style="-fx-font-size: 12; -fx-padding: 8;" onAction="#handleResetAction"/>
            </HBox>
            
            <HBox spacing="5.0" style="-fx-alignment: center;">
               <Label text="Belum punya akun?" />
               <Hyperlink text="Daftar di sini" onAction="#handleRegisterAction" style="-fx-padding: 0; -fx-font-size: 12;" />
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
