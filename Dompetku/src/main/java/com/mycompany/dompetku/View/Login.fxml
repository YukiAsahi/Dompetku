<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="200.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="com.mycompany.dompetku.View.LoginController">
   <children>
      <Label layoutX="84.0" layoutY="27.0" text="Nama" />
      <Label layoutX="267.0" layoutY="27.0" text="Password" />
      <TextField fx:id="usernameInput" layoutX="30.0" layoutY="44.0" />
      <PasswordField fx:id="passwordInput" layoutX="218.0" layoutY="44.0" />
      <Button layoutX="72.0" layoutY="125.0" mnemonicParsing="false" text="Login" onAction="#handleLoginAction"/>
      <Button layoutX="276.0" layoutY="125.0" mnemonicParsing="false" text="OK" onAction="#handleOkAction"/>
   </children>
</AnchorPane>
